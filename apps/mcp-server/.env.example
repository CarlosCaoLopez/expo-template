# MCP Server environment variables — copy to .env

# Transport: "stdio" for local use (Claude Desktop), "http" for remote
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=3002

# Optional: backend API URL if the MCP server proxies requests
BACKEND_URL=http://localhost:3001
